@page "/forgot-password"
@layout AuthLayout
@inject ECommerceUI.Services.AuthService AuthService
@inject NavigationManager Navigation
@using ECommerceUI.Models.Auth

<div class="auth-page">
    <div class="auth-card">

        <h2 class="auth-main-title">FORGOT PASSWORD?</h2>

        <div class="auth-body">

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="auth-message error">@errorMessage</div>
            }

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="auth-message success">@successMessage</div>
            }

            <EditForm Model="@forgotModel"
                      OnValidSubmit="HandleForgot">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="auth-input">
                    <span class="icon">✉</span>
                    <InputText @bind-Value="forgotModel.Email"
                               placeholder="Email address" />
                </div>

                <div class="auth-input">
                    <span class="icon">📱</span>
                    <InputText @bind-Value="forgotModel.Phone"
                               placeholder="Phone number" />
                </div>

                <div class="auth-button-area">
                    <button class="auth-btn" type="submit"
                            disabled="@isLoading">
                        @(isLoading ? "SENDING OTP..." : "SEND OTP")
                    </button>
                </div>

                <div style="text-align:center;
                    margin-top:14px;
                    font-size:14px;">
                    <a href="/login">Back to Login</a>
                </div>

            </EditForm>

        </div>
    </div>
</div>

@code {
    private ForgotPasswordModel forgotModel = new();
    private string errorMessage = string.Empty;
    private string successMessage = string.Empty;
    private bool isLoading = false;

    private async Task HandleForgot()
    {
        errorMessage = string.Empty;
        successMessage = string.Empty;
        isLoading = true;

        var result = await AuthService.ForgotPasswordAsync(forgotModel);

        isLoading = false;

        switch (result)
        {
            case "not_found":
                errorMessage =
                    "No account found with this email address.";
                break;
            case "mismatch":
                errorMessage =
                    "Email and phone number do not match our records.";
                break;
            default:
                Navigation.NavigateTo(
                    $"/verify-otp?email={Uri.EscapeDataString(forgotModel.Email)}&phone={Uri.EscapeDataString(forgotModel.Phone)}");
                break;
        }
    }
}