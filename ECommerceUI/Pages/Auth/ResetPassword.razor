@page "/reset-password"
@layout AuthLayout
@inject ECommerceUI.Services.AuthService AuthService
@inject NavigationManager Navigation
@using ECommerceUI.Models.Auth
@using Microsoft.AspNetCore.WebUtilities

<div class="auth-page">
    <div class="auth-card">

        <h2 class="auth-main-title">RESET PASSWORD</h2>

        <div class="auth-body">

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="auth-message error">@errorMessage</div>
            }

            <EditForm Model="@resetModel"
                      OnValidSubmit="HandleReset">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="auth-input">
                    <span class="icon">🔒</span>
                    <InputText @bind-Value="resetModel.NewPassword"
                               type="password"
                               placeholder="New password" />
                </div>

                <div class="auth-input">
                    <span class="icon">🔒</span>
                    <InputText @bind-Value="resetModel.ConfirmPassword"
                               type="password"
                               placeholder="Confirm new password" />
                </div>

                <div class="auth-button-area">
                    <button class="auth-btn" type="submit"
                            disabled="@isLoading">
                        @(isLoading ? "RESETTING..." : "RESET PASSWORD")
                    </button>
                </div>

            </EditForm>

        </div>
    </div>
</div>

@code {
    private ResetPasswordModel resetModel = new();
    private string errorMessage = string.Empty;
    private bool isLoading = false;

    protected override void OnInitialized()
    {
        var uri = Navigation.ToAbsoluteUri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("email", out var e))
            resetModel.Email = e!;

        if (query.TryGetValue("otp", out var o))
            resetModel.Otp = o!;

        if (string.IsNullOrEmpty(resetModel.Email) ||
            string.IsNullOrEmpty(resetModel.Otp))
            Navigation.NavigateTo("/forgot-password");
    }

    private async Task HandleReset()
    {
        errorMessage = string.Empty;

        if (resetModel.NewPassword != resetModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isLoading = true;

        var result = await AuthService.ResetPasswordAsync(resetModel);

        isLoading = false;

        switch (result)
        {
            case "ok":
                Navigation.NavigateTo("/login?reset=success", true);
                break;
            case "invalid":
                errorMessage =
                    "OTP expired. Please start over.";
                Navigation.NavigateTo("/forgot-password");
                break;
            default:
                errorMessage =
                    "Something went wrong. Please try again.";
                break;
        }
    }
}