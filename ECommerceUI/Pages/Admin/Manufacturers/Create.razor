@page "/admin/manufacturers/create"
@layout AdminLayout
@inject ManufacturerService ManufacturerService
@inject NavigationManager Navigation

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0">Add Manufacturer</h3>

    <button class="btn btn-secondary" @onclick="GoBack">
        ← Back to Manufacturers
    </button>
</div>

<div class="card">
    <div class="card-body">

        <div class="mb-3">
            <label>Name</label>
            <input class="form-control" @bind="model.Name" />
        </div>

        <div class="mb-3">
            <label>Display Order</label>
            <input type="number"
                   class="form-control"
                   @bind="model.DisplayOrder" />
        </div>

        <div class="form-check">
            <input type="checkbox"
                   class="form-check-input"
                   @bind="model.Published" />
            <label class="form-check-label">Published</label>
        </div>
        <div class="text-center mb-5">
            <button class="btn btn-success px-5" @onclick="Save">
                Save
            </button>
        </div>

    </div>
</div>

@code {

    private ManufacturerDto model = new();

    async Task Save()
    {
        var dto = new CreateManufacturerDto
        {
            Name = model.Name,
            DisplayOrder = model.DisplayOrder,
            Published = model.Published
        };

        await ManufacturerService.Create(dto);

        Navigation.NavigateTo("/admin/manufacturers?success=created", true);
    }

    void Cancel()
    {
        Navigation.NavigateTo("/admin/manufacturers");
    }
    private void GoBack()
    {
        Navigation.NavigateTo("/admin/manufacturers");
    }
}