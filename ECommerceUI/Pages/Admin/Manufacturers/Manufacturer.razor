@page "/admin/manufacturers"
@layout AdminLayout
@inject ManufacturerService manufacturerService
@inject NavigationManager Navigation

<h2 class="d-flex justify-content-between align-items-center mb-4">
    <span>Manufacturers</span>
    <button class="btn btn-primary" @onclick="GoToCreate">
        + Add New
    </button>
</h2>

<!-- SEARCH CARD -->
<div class="card mb-4">
    <div class="card-header fw-bold">Search</div>
    <div class="card-body">

        <div class="row g-3">

            <div class="col-md-6">
                <label class="form-label">Manufacturer Name:</label>
                <input type="text"
                       class="form-control"
                       @bind="searchName"
                       placeholder="All" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Published:</label>
                <select class="form-select"
                        @bind="searchPublished">
                    <option value="">All</option>
                    <option value="true">Published</option>
                    <option value="false">Unpublished</option>
                </select>
            </div>

        </div>

        <div class="text-center mt-3">
            <button class="btn btn-primary px-4"
                    @onclick="Search">
                Search
            </button>
        </div>

    </div>
</div>


<!-- TABLE -->
<table class="table table-bordered table-hover">

    <thead class="table-light">
        <tr>
            <th style="width:40px;"></th>
            <th>Name</th>
            <th>Published</th>
            <th>Display Order</th>
            <th style="width:120px;">Actions</th>
        </tr>
    </thead>

    <tbody>

        @if (!manufacturers.Any())
        {
            <tr>
                <td colspan="5" class="text-center">
                    No manufacturers found
                </td>
            </tr>
        }
        else
        {
            @foreach (var item in manufacturers)
            {
                <tr>
                    <td>
                        <input type="checkbox" />
                    </td>

                    <td>@item.Name</td>

                    <td>
                        @(item.Published ? "Yes" : "No")
                    </td>

                    <td>@item.DisplayOrder</td>

                    <td>
                        <button class="btn btn-warning btn-sm"
                                @onclick="() => Edit(item.Id)">
                            Edit
                        </button>
                    </td>
                </tr>
            }
        }

    </tbody>

</table>


@code {

    private List<ManufacturerDto> manufacturers = new();
    private string searchName = "";
    private string searchPublished = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        manufacturers = await manufacturerService.GetAll();
    }

    private async Task Search()
    {
        if (string.IsNullOrWhiteSpace(searchName))
        {
            await LoadData();
        }
        else
        {
            manufacturers = await manufacturerService.Search(searchName);
        }
    }

    private void GoToCreate()
    {
        Navigation.NavigateTo("/admin/manufacturers/create");
    }

    private void Edit(string id)
    {
        Navigation.NavigateTo($"/admin/manufacturers/edit/{id}");
    }
}