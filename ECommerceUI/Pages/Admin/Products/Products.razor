@page "/admin/products"
@layout AdminLayout

@inject IJSRuntime JS
@* @inject HttpClient Http *@
@using System.Text.Json
@using System.Text.Json.Serialization


@inject NavigationManager Nav
@inject IConfiguration Configuration

@inject ProductService ProductService

@using ECommerceUI.Models.Catalog
@using ECommerceUI.Models.Catalog.Enums
@inject HttpClient Http
@inject NavigationManager Navigation

<h2 class="d-flex justify-content-between align-items-center mb-4">
    <span>Products</span>
    <div>
        <button class="btn btn-primary me-2" @onclick="GoToCreate">+ Add New</button>
        @* <button class="btn btn-danger" @onclick="DeleteSelected">Delete Selected</button> *@
    </div>
</h2>

<!-- SEARCH PANEL -->
<div class="card mb-4">
    <div class="card-header fw-bold">Search Products</div>
    <div class="card-body">
        <div class="row g-3">

            <div class="col-md-6">
                <label class="form-label">Product Name:</label>
                <input class="form-control" @bind="searchModel.ProductName" placeholder="Enter product name" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Category:</label>
                <select class="form-select" @bind="searchModel.CategoryId">
                    <option value="">All Categories</option>
                    @foreach (var c in categories)
                    {
                        <option value="@c.Id">@c.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">SKU:</label>
                <input class="form-control" @bind="searchModel.SKU" placeholder="Enter SKU" />
            </div>

            <div class="col-md-6">
                <label class="form-label">Product Type:</label>
                <select class="form-select" @bind="searchModel.ProductType">
                    <option value="">All Types</option>
                    @foreach (var type in Enum.GetValues<ProductType>())
                    {
                        <option value="@type">@type.ToString()</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Manufacturer:</label>
                <select class="form-select" @bind="searchModel.ManufacturerId">
                    <option value="">All Manufacturers</option>
                    @foreach (var m in manufacturers)
                    {
                        <option value="@m.Id">@m.Name</option>
                    }
                </select>
            </div>

            <div class="col-md-6">
                <label class="form-label">Published:</label>
                <select class="form-select" @bind="searchModel.Published">
                    <option value="">All</option>
                    <option value="true">Yes</option>
                    <option value="false">No</option>
                </select>
            </div>

            <div class="col-12 text-center mt-3">
                <button class="btn btn-primary px-5" @onclick="FilterProducts">Search</button>
            </div>

        </div>
    </div>
</div>

<table class="table table-striped table-bordered align-middle">
    <thead>
        <tr>
            <th style="width: 40px;">
                <input type="checkbox" @onclick="ToggleAll" />
            </th>
            <th>Image</th>
            <th>Name</th>
            <th>SKU</th>
            <th style="width:100px;">Price</th>
            <th style="width:80px;">Stock</th>
            <th style="width:120px;">Type</th>
            <th style="width:100px;">Published</th>
            <th style="width:140px;">Actions</th>
        </tr>
    </thead>
    <tbody>
        @if (!filteredProducts.Any())
        {
            <tr>
                <td colspan="8" class="text-center">No products found</td>
            </tr>
        }
        else
        {
            @foreach (var p in filteredProducts)
            {
                <tr>
                    <td>
                        <input type="checkbox" @bind="p.IsSelected" />
                    </td>
                    <!-- IMAGE COLUMN -->
                    <td>
                    
                        @if (p.ImageUrls != null && p.ImageUrls.Any())
                        {
                            <img src="@($"https://localhost:5001/{p.ImageUrls.First()}")" width="60" />

                        }
                        else
                        {
                            <span>No Image</span>
                        }

                    </td>

                    <td>@p.ProductName</td>
                    <td>@p.SKU</td>
                    <td>@p.Price.ToString("C")</td>
                    <td>@p.StockQuantity</td>
                    <td>@p.ProductType.ToString()</td>

                    <td>@(p.Published ? "Yes" : "No")</td>
                    <td>
                        <button class="btn btn-sm btn-warning me-1" @onclick="() => EditProduct(p.Id)">Edit</button>
                        <button class="btn btn-sm btn-danger"
                                @onclick="() => DeleteProduct(p.Id)">
                            Delete
                        </button>

                    </td>
                </tr>
            }
        }
    </tbody>
</table>

@code {
    private ProductSearchDto searchModel = new();
    private List<ProductVm> products = new();
    private List<ProductVm> filteredProducts = new();
    private List<ManufacturerVm> manufacturers = new();
    private List<CategoryVm> categories = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
        try
        {
            categories = await Http.GetFromJsonAsync<List<CategoryVm>>("api/catalog/categories/GetAll") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading categories: " + ex.Message);
        }

        try
        {
            manufacturers = await Http.GetFromJsonAsync<List<ManufacturerVm>>("api/manufacturers/GetAll") ?? new();
        }
        catch (Exception ex)
        {
            Console.WriteLine("Error loading manufacturers: " + ex.Message);
        }
    }

    private async Task LoadProducts()
    {
        var options = new JsonSerializerOptions
        {
            PropertyNameCaseInsensitive = true
        };
        options.Converters.Add(new JsonStringEnumConverter());

        products = await Http.GetFromJsonAsync<List<ProductVm>>(
            "api/catalog/products/GetAll",
            options
        ) ?? new();

        filteredProducts = new List<ProductVm>(products);
    }




    private async Task FilterProducts()
    {
        var response = await Http.PostAsJsonAsync("api/catalog/products/search", searchModel);
        if (response.IsSuccessStatusCode)
        {
            var options = new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            };
            options.Converters.Add(new JsonStringEnumConverter());

            filteredProducts = await response.Content.ReadFromJsonAsync<List<ProductVm>>(options) ?? new List<ProductVm>();
        }
    }


    private void GoToCreate() => Navigation.NavigateTo("/admin/products/create");
    private void EditProduct(string id) => Navigation.NavigateTo($"/admin/products/edit/{id}");

    private async Task DeleteProduct(string id)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", "Are you sure you want to delete this product?");
        if (!confirmed) return;

        await ProductService.Delete(id);
        await LoadProducts();
    }
    void GoBack()
    {
        Navigation.NavigateTo("/admin/products");
    }

    private void ToggleAll()
    {
        bool allSelected = filteredProducts.All(x => x.IsSelected);
        foreach (var p in filteredProducts)
            p.IsSelected = !allSelected;
    }
}
