@page "/"
@inject HttpClient Http
@inject NavigationManager Navigation
@using ECommerceUI.Models.Catalog
@using ECommerceUI.Models.HomePage

<div class="home-container">

    <!-- HERO BANNER -->
    @if (banners != null && banners.Any())
    {
        <div class="hero-slider">

            <button class="slider-btn left" @onclick="PrevBanner">
                &#10094;
            </button>

            <img src="https://localhost:5001@(banners[current].ImageUrl)"
                 class="hero-img"
                 @onclick="() => OpenLink(banners[current].ButtonLink)" />

            <button class="slider-btn right" @onclick="NextBanner">
                &#10095;
            </button>

        </div>
    }

    <!-- CATEGORY SECTION -->
    <div class="section">

        <h3 class="section-title">Shop by Category</h3>

        <div class="category-grid">

            @foreach (var category in categories.Where(x => x.Published))
            {
                <div class="category-card"
                     @onclick="() => LoadProducts(category.Id)">

                    <div class="cat-name">
                        @category.Name
                    </div>

                </div>
            }

        </div>

    </div>

    <!-- PRODUCT SECTION -->
    <div class="section">

        <h3 class="section-title">Featured Products</h3>

        <div class="product-grid">

            @foreach (var product in products.Where(p => p.Published))
            {
                <div class="product-card">

                    <img src="@GetProductImage(product)" />

                    <div class="product-info">

                        <h5>@product.ProductName</h5>

                        <div class="price">
                            $@product.Price
                        </div>

                        <button class="add-btn">
                            Add to Cart
                        </button>

                    </div>

                </div>
            }

        </div>

    </div>

</div>

@code {

    List<CategoryDto> categories = new();
    List<ProductDto> products = new();
    List<HeroBannerDto> banners = new();

    int current = 0;
    System.Timers.Timer timer;

    protected override async Task OnInitializedAsync()
    {
        categories = await Http.GetFromJsonAsync<List<CategoryDto>>
        ("api/catalog/categories/GetAll");

        products = await Http.GetFromJsonAsync<List<ProductDto>>
        ("api/catalog/products/GetAll");

        banners = await Http.GetFromJsonAsync<List<HeroBannerDto>>
        ("api/banners");

        StartSlider();
    }

    void StartSlider()
    {
        timer = new System.Timers.Timer(4000);
        timer.Elapsed += RotateBanner;
        timer.Start();
    }

    void RotateBanner(object sender, System.Timers.ElapsedEventArgs e)
    {
        if (banners == null || banners.Count == 0)
            return;

        current++;

        if (current >= banners.Count)
            current = 0;

        InvokeAsync(StateHasChanged);
    }

    void NextBanner()
    {
        current++;
        if (current >= banners.Count)
            current = 0;
    }

    void PrevBanner()
    {
        current--;
        if (current < 0)
            current = banners.Count - 1;
    }

    async Task LoadProducts(string categoryId)
    {
        products = await Http.GetFromJsonAsync<List<ProductDto>>
        ($"api/catalog/products/GetByCategory/{categoryId}");
    }

    void OpenLink(string link)
    {
        Navigation.NavigateTo(link);
    }

    string GetProductImage(ProductDto product)
    {
        if (product.ImageUrls != null && product.ImageUrls.Any())
        {
            return "https://localhost:5001/" + product.ImageUrls.First();
        }

        return "/images/no-image.png";
    }

}