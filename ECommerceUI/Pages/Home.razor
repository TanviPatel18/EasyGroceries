@page "/"
@inject HttpClient Http
@inject NavigationManager Navigation
@using ECommerceUI.Models.Catalog
@using ECommerceUI.Models.HomePage
@using Microsoft.AspNetCore.Components.Authorization

<div class="">

    @if (banners != null && banners.Any())
    {
        <div class="hero-slider home-container slider-section">

            <button class="slider-btn left" @onclick="PrevBanner">
                &#10094;
            </button>

            <img src="https://localhost:5001@(banners[current].ImageUrl)"
                 class="hero-img"
                 @onclick="() => OpenLink(banners[current].ButtonLink)" />

            <button class="slider-btn right" @onclick="NextBanner">
                &#10095;
            </button>

            <div class="slider-dots">
                @for (int i = 0; i < banners.Count; i++)
                {
                    var idx = i;
                    <span class="dot @(idx == current ? "active" : "")"
                          @onclick="() => current = idx"></span>
                }
            </div>

        </div>
    }

    <div class="shopcategory-section">

        <h3 class="section-title">Shop by Category</h3>

        <div class="category-wrapper">
            <div class="category-grid"
                 style="transform: translateX(-@(currentCategoryIndex* cardStep)px);
                transition:@(isResetting ? "none" : "transform 0.5s ease-in-out");">

                @foreach (var category in categories.Where(x => x.Published))
                {
                    <div class="category-card"
                         @onclick="() => LoadProducts(category.Id)">

                        <div class="category-img-wrap">
                            <img src="@GetCategoryImage(category)" class="category-img" alt="@category.Name" />
                        </div>

                        <div class="category-name">@category.Name</div>

                    </div>
                }

            </div>
        </div>

    </div>

    <!-- PRODUCT SECTION -->
    <div class=" featured-product">

        <h3 class="section-title">Featured Products</h3>

        <div class="product-grid">

            @foreach (var product in products.Where(p => p.Published))
            {
                <div class="product-card">

                    <div class="product-img-wrap">
                        <img src="@GetProductImage(product)" alt="@product.ProductName" />
                    </div>

                    <div class="product-info">

                        <h5 class="product-name">@product.ProductName</h5>

                        <div class="price">$@product.Price</div>

                        <div class="action-row">

                            <button class="wishlist-btn @(IsInWishlist(product) ? "active" : "")"
                                    @onclick="() => ToggleWishlist(product)">
                                <i class="@(IsInWishlist(product) ? "fa-solid fa-heart" : "fa-regular fa-heart")"></i>
                            </button>

                            <button class="add-btn">Add to Cart</button>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</div>

<!-- SELLER CTA -->
<div class="seller-banner">
    <div class="seller-text">
        <h2>Want to become a seller?</h2>
        <p>Start selling your products to thousands of customers</p>
    </div>
    <button class="seller-btn">Become a Seller</button>
</div>


@code {

    List<CategoryDto> categories = new();
    List<ProductDto> products = new();
    List<HeroBannerDto> banners = new();

    int current = 0;
    System.Timers.Timer timer;

    protected override async Task OnInitializedAsync()
    {
        categories = await Http.GetFromJsonAsync<List<CategoryDto>>
        ("api/catalog/categories/GetAll");

        products = await Http.GetFromJsonAsync<List<ProductDto>>
        ("api/catalog/products/GetAll");

        banners = await Http.GetFromJsonAsync<List<HeroBannerDto>>
        ("api/banners");

        StartSlider();
        StartCategorySlider();
    }

    void StartSlider()
    {
        timer = new System.Timers.Timer(4000);
        timer.Elapsed += RotateBanner;
        timer.Start();
    }

    void RotateBanner(object sender, System.Timers.ElapsedEventArgs e)
    {
        if (banners == null || banners.Count == 0)
            return;

        current++;

        if (current >= banners.Count)
            current = 0;

        InvokeAsync(StateHasChanged);
    }

    void NextBanner()
    {
        current++;
        if (current >= banners.Count)
            current = 0;
    }

    void PrevBanner()
    {
        current--;
        if (current < 0)
            current = banners.Count - 1;
    }

    async Task LoadProducts(string categoryId)
    {
        products = await Http.GetFromJsonAsync<List<ProductDto>>
        ($"api/catalog/products/GetByCategory/{categoryId}");
    }

    void OpenLink(string link)
    {
        Navigation.NavigateTo(link);
    }

    string GetProductImage(ProductDto product)
    {
        if (product.ImageUrls != null && product.ImageUrls.Any())
        {
            return "https://localhost:5001/" + product.ImageUrls.First();
        }

        return "/images/no-image.png";
    }

    string GetCategoryImage(CategoryDto category)
    {
        if (!string.IsNullOrEmpty(category.ImageUrl))
        {
            return "https://localhost:5001/" + category.ImageUrl;
        }

        return "/images/no-image.png";
    }

    // category slider
    int currentCategoryIndex = 0;
    int cardStep = 180;
    bool isResetting = false;

    System.Timers.Timer categoryTimer;

    void StartCategorySlider()
    {
        categoryTimer = new System.Timers.Timer(2500);
        categoryTimer.Elapsed += RotateCategory;
        categoryTimer.Start();
    }

    void RotateCategory(object sender, System.Timers.ElapsedEventArgs e)
    {
        if (categories == null || categories.Count == 0)
            return;

        var first = categories[0];
        categories.RemoveAt(0);
        categories.Add(first);

        InvokeAsync(StateHasChanged);
    }

    // wishlist ui
    HashSet<string> wishlist = new();

    void ToggleWishlist(ProductDto product)
    {
        if (wishlist.Contains(product.Id))
            wishlist.Remove(product.Id);
        else
            wishlist.Add(product.Id);
    }

    bool IsInWishlist(ProductDto product)
    {
        return wishlist.Contains(product.Id);
    }

}
