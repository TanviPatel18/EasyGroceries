@page "/my-account"
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject HttpClient Http
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components.WebAssembly.Http
@using System.Net.Http.Json
@using ECommerceUI.Services.other
@using ECommerceUI.Models.Account
@using ECommerceUI.Models.Auth
@using ECommerceUI.Services
@inject AccountService AccountSvc
@inject AuthService AuthSvc
@inject AddressService AddressSvc
@inject AuthenticationStateProvider AuthStateProvider
@attribute [Authorize]

<div class="acc-page">

    <div class="acc-header">
        <button class="page-topbar-back" @onclick="GoBack">
            <i class="fa-solid fa-arrow-left"></i>
        </button>
        <h2 class="acc-title">My Account</h2>
    </div>

    @if (isLoading)
    {
        <div class="acc-loading">Loading profile...</div>
    }
    else if (activeTab == "menu")
    {
        <div class="acc-top-card">
            <div class="acc-avatar">
                @((!string.IsNullOrEmpty(profile?.FirstName) ? profile.FirstName[0].ToString().ToUpper() : "U"))
                @((!string.IsNullOrEmpty(profile?.LastName) ? profile.LastName[0].ToString().ToUpper() : ""))
            </div>
            <div>
                <div class="acc-top-name">@profile?.FirstName @profile?.LastName</div>
                <div class="acc-top-email">@profile?.Email</div>
                <div class="acc-top-joined">
                    Member since @profile?.RegistrationDate.ToString("MMM yyyy")
                </div>
            </div>
        </div>

        <div class="acc-menu-list">

            <div class="acc-menu-item" @onclick='() => activeTab = "profile"'>
                <div class="acc-item-icon acc-icon-blue">&#128100;</div>
                <div class="acc-item-body">
                    <div class="acc-item-title">Personal Details</div>
                    <div class="acc-item-sub">Name, phone number</div>
                </div>
                <div class="acc-item-arrow">&#8250;</div>
            </div>

            <div class="acc-menu-item" @onclick='() => activeTab = "address"'>
                <div class="acc-item-icon acc-icon-blue">
                    <i class="fa-solid fa-location-dot"></i>
                </div>
                <div class="acc-item-body">
                    <div class="acc-item-title">Address Book</div>
                    <div class="acc-item-sub">Manage delivery addresses</div>
                </div>
                <div class="acc-item-arrow">&#8250;</div>
            </div>

            <div class="acc-menu-item" @onclick='() => activeTab = "password"'>
                <div class="acc-item-icon acc-icon-green">&#128274;</div>
                <div class="acc-item-body">
                    <div class="acc-item-title">Password &amp; Security</div>
                    <div class="acc-item-sub">Change your password</div>
                </div>
                <div class="acc-item-arrow">&#8250;</div>
            </div>

            <div class="acc-menu-item acc-item-danger"
                 @onclick='() => activeTab = "delete"'>
                <div class="acc-item-icon acc-icon-red">&#128465;</div>
                <div class="acc-item-body">
                    <div class="acc-item-title">Delete Account</div>
                    <div class="acc-item-sub">Permanently remove account</div>
                </div>
                <div class="acc-item-arrow">&#8250;</div>
            </div>

            <div class="acc-menu-item acc-item-logout" @onclick="Logout">
                <div class="acc-item-icon acc-icon-gray">&#128682;</div>
                <div class="acc-item-body">
                    <div class="acc-item-title">Logout</div>
                    <div class="acc-item-sub">Sign out of your account</div>
                </div>
                <div class="acc-item-arrow">&#8250;</div>
            </div>

        </div>
    }
    else
    {
        <div class="acc-layout">

            <div class="acc-left">

                <div class="acc-top-card">
                    <div class="acc-avatar">
                        @((!string.IsNullOrEmpty(profile?.FirstName) ? profile.FirstName[0].ToString().ToUpper() : "U"))
                        @((!string.IsNullOrEmpty(profile?.LastName) ? profile.LastName[0].ToString().ToUpper() : ""))
                    </div>
                    <div>
                        <div class="acc-top-name">@profile?.FirstName @profile?.LastName</div>
                        <div class="acc-top-email">@profile?.Email</div>
                        <div class="acc-top-joined">
                            Member since @profile?.RegistrationDate.ToString("MMM yyyy")
                        </div>
                    </div>
                </div>

                <div class="acc-menu-list">

                    <div class="acc-menu-item @(activeTab == "profile" ? "active" : "")"
                         @onclick='() => activeTab = "profile"'>
                        <div class="acc-item-icon acc-icon-blue">&#128100;</div>
                        <div class="acc-item-body">
                            <div class="acc-item-title">Personal Details</div>
                            <div class="acc-item-sub">Name, phone number</div>
                        </div>
                        <div class="acc-item-arrow">&#8250;</div>
                    </div>

                    <div class="acc-menu-item @(activeTab == "address" ? "active" : "")"
                         @onclick='() => activeTab = "address"'>
                        <div class="acc-item-icon acc-icon-blue">
                            <i class="fa-solid fa-location-dot"></i>
                        </div>
                        <div class="acc-item-body">
                            <div class="acc-item-title">Address Book</div>
                            <div class="acc-item-sub">Manage delivery addresses</div>
                        </div>
                        <div class="acc-item-arrow">&#8250;</div>
                    </div>

                    <div class="acc-menu-item @(activeTab == "password" ? "active" : "")"
                         @onclick='() => activeTab = "password"'>
                        <div class="acc-item-icon acc-icon-green">&#128274;</div>
                        <div class="acc-item-body">
                            <div class="acc-item-title">Password &amp; Security</div>
                            <div class="acc-item-sub">Change your password</div>
                        </div>
                        <div class="acc-item-arrow">&#8250;</div>
                    </div>

                    <div class="acc-menu-item @(activeTab == "delete" ? "active" : "") acc-item-danger"
                         @onclick='() => activeTab = "delete"'>
                        <div class="acc-item-icon acc-icon-red">&#128465;</div>
                        <div class="acc-item-body">
                            <div class="acc-item-title">Delete Account</div>
                            <div class="acc-item-sub">Permanently remove account</div>
                        </div>
                        <div class="acc-item-arrow">&#8250;</div>
                    </div>

                    <div class="acc-menu-item acc-item-logout" @onclick="Logout">
                        <div class="acc-item-icon acc-icon-gray">&#128682;</div>
                        <div class="acc-item-body">
                            <div class="acc-item-title">Logout</div>
                            <div class="acc-item-sub">Sign out of your account</div>
                        </div>
                        <div class="acc-item-arrow">&#8250;</div>
                    </div>

                </div>
            </div>

            <div class="acc-right">

                @* ══════════════ PROFILE TAB ══════════════ *@
                @if (activeTab == "profile")
                {
                    <div class="acc-card">
                        <div class="acc-card-title">Personal Details</div>
                        @if (!string.IsNullOrEmpty(profileSuccess))
                        {
                            <div class="acc-success">&#10003; @profileSuccess</div>
                        }
                        @if (!string.IsNullOrEmpty(profileError))
                        {
                            <div class="acc-error">&#10007; @profileError</div>
                        }
                        <div class="acc-form-row">
                            <div class="acc-form-group">
                                <label>First Name</label>
                                <input @bind="editDto.FirstName" placeholder="First name" />
                            </div>
                            <div class="acc-form-group">
                                <label>Last Name</label>
                                <input @bind="editDto.LastName" placeholder="Last name" />
                            </div>
                        </div>
                        <div class="acc-form-group">
                            <label>Email</label>
                            <input value="@profile?.Email" disabled class="acc-disabled" />
                        </div>
                        <div class="acc-form-group">
                            <label>Phone</label>
                            <input @bind="editDto.Phone" placeholder="Phone number" />
                        </div>
                        <button class="acc-save-btn" disabled="@isSaving"
                                @onclick="SaveProfile">
                            @(isSaving ? "Saving..." : "Save Changes")
                        </button>
                    </div>
                }

                @* ══════════════ ADDRESS TAB ══════════════ *@
                @if (activeTab == "address")
                {
                    <div class="acc-card">

                        <div style="display:flex;justify-content:space-between;align-items:center">
                            <div class="acc-card-title">Address Book</div>
                            <button class="acc-save-btn" @onclick="OpenAddForm">
                                <i class="fa-solid fa-plus"></i> Add Address
                            </button>
                        </div>

                        @if (!string.IsNullOrEmpty(addressSuccess))
                        {
                            <div class="acc-success">&#10003; @addressSuccess</div>
                        }
                        @if (!string.IsNullOrEmpty(addressError))
                        {
                            <div class="acc-error">&#10007; @addressError</div>
                        }

                        @* ── Add / Edit Form ── *@
                        @if (showAddAddress)
                        {
                            <div style="margin-top:20px;padding:16px;
                                border:1px solid #e0e0e0;border-radius:10px">

                                <div class="acc-card-title"
                                     style="font-size:15px;margin-bottom:12px">
                                    @(editingAddress != null ? "Edit Address" : "New Address")
                                </div>

                                <div class="acc-form-row">
                                    <div class="acc-form-group">
                                        <label>Full Name</label>
                                        <input @bind="addressForm.FullName"
                                               placeholder="John Doe" />
                                    </div>
                                    <div class="acc-form-group">
                                        <label>Phone</label>
                                        <input @bind="addressForm.PhoneNumber"
                                               placeholder="9876543210" />
                                    </div>
                                </div>

                                <div class="acc-form-group">
                                    <label>Address Line 1</label>
                                    <input @bind="addressForm.AddressLine1"
                                           placeholder="House No, Street Name" />
                                </div>

                                <div class="acc-form-group">
                                    <label>
                                        Address Line 2
                                        <span style="color:#aaa;font-size:12px">(optional)</span>
                                    </label>
                                    <input @bind="addressForm.AddressLine2"
                                           placeholder="Apartment, Floor, etc." />
                                </div>

                                <div class="acc-form-row">
                                    <div class="acc-form-group">
                                        <label>
                                            Landmark
                                            <span style="color:#aaa;font-size:12px">(optional)</span>
                                        </label>
                                        <input @bind="addressForm.Landmark"
                                               placeholder="Near XYZ Mall" />
                                    </div>
                                    <div class="acc-form-group">
                                        <label>City</label>
                                        <input @bind="addressForm.City"
                                               placeholder="Surat" />
                                    </div>
                                </div>

                                <div class="acc-form-row">
                                    <div class="acc-form-group">
                                        <label>State</label>
                                        <input @bind="addressForm.State"
                                               placeholder="Gujarat" />
                                    </div>
                                    <div class="acc-form-group">
                                        <label>ZIP Code</label>
                                        <input @bind="addressForm.ZipCode"
                                               placeholder="395001" />
                                    </div>
                                </div>

                                <div class="acc-form-group">
                                    <label>Address Type</label>
                                    <select @bind="addressForm.AddressType"
                                            style="width:100%;padding:10px;
                                        border:1px solid #ddd;
                                        border-radius:8px">
                                        <option value="Home">🏠 Home</option>
                                        <option value="Work">💼 Work</option>
                                        <option value="Other">📍 Other</option>
                                    </select>
                                </div>

                                <div style="display:flex;align-items:center;
                                    gap:8px;margin-bottom:14px">
                                    <input type="checkbox" id="isDefault"
                                           @bind="addressForm.IsDefault" />
                                    <label for="isDefault"
                                           style="margin:0;font-size:14px">
                                        Set as default address
                                    </label>
                                </div>

                                <div style="display:flex;gap:10px">
                                    <button class="acc-save-btn"
                                            disabled="@isSaving"
                                            @onclick="SaveAddress">
                                        @if (isSaving)
                                        {
                                            <span>Saving...</span>
                                        }
                                        else
                                        {
                                            <span>
                                                @(editingAddress != null
                                                    ? "Update Address"
                                                    : "Save Address")
                                            </span>
                                        }
                                    </button>
                                    <button class="acc-cancel-btn"
                                            @onclick="CloseAddressForm">
                                        Cancel
                                    </button>
                                </div>

                            </div>
                        }

                        @* ── Address Cards ── *@
                        <div style="margin-top:25px">
                            @if (addresses == null || !addresses.Any())
                            {
                                <div style="text-align:center;color:#aaa;padding:30px 0">
                                    <i class="fa-solid fa-location-dot"
                                       style="font-size:32px;margin-bottom:10px"></i>
                                    <p>No address saved yet.</p>
                                </div>
                            }
                            else
                            {
                                @foreach (var a in addresses)
                                {
                                    <div class="acc-card @(a.IsDefault ? "default-card" : "")">

                                        <!-- TOP ROW -->
                                        <div class="acc-address-top">

                                            <!-- LEFT TAGS -->
                                            <div class="acc-address-tags">
                                                <span class="tag-home">@a.AddressType</span>

                                                @if (a.IsDefault)
                                                {
                                                    <span class="tag-default">Default</span>
                                                }
                                            </div>

                                            <!-- RIGHT BUTTONS -->
                                            <div class="acc-address-actions">
                                                <button class="acc-save-btn"
                                                        @onclick="() => OpenEditForm(a)">
                                                    <i class="fa-solid fa-pencil"></i> Edit
                                                </button>

                                                <button class="acc-delete-btn"
                                                        @onclick="() => DeleteAddress(a.Id)">
                                                    <i class="fa-solid fa-trash"></i> Delete
                                                </button>
                                            </div>

                                        </div>

                                        <!-- NAME + PHONE -->
                                        <div class="acc-address-name">
                                            <b>@a.FullName</b>
                                            <span>@a.PhoneNumber</span>
                                        </div>

                                        <!-- ADDRESS -->
                                        <div class="acc-address-text">
                                            <div>@a.AddressLine1</div>

                                            @if (!string.IsNullOrEmpty(a.AddressLine2))
                                            {
                                                <div>@a.AddressLine2</div>
                                            }

                                            @if (!string.IsNullOrEmpty(a.Landmark))
                                            {
                                                <div>Near: @a.Landmark</div>
                                            }

                                            <div>@a.City, @a.State — @a.ZipCode</div>
                                            <div>@a.Country</div>
                                        </div>

                                    </div>
                                }
                            }
                        </div>

                    </div>
                }

                @* ══════════════ PASSWORD TAB ══════════════ *@
                @if (activeTab == "password")
                {
                    <div class="acc-card">
                        <div class="acc-card-title">Password &amp; Security</div>
                        @if (!string.IsNullOrEmpty(passSuccess))
                        {
                            <div class="acc-success">&#10003; @passSuccess</div>
                        }
                        @if (!string.IsNullOrEmpty(passError))
                        {
                            <div class="acc-error">&#10007; @passError</div>
                        }
                        <p class="acc-pass-info">
                            To change your password we will send
                            an OTP to your registered email address.
                        </p>
                        @if (!otpSent)
                        {
                            <button class="acc-save-btn" disabled="@isSaving"
                                    @onclick="SendOtp">
                                @(isSaving ? "Sending..." : "Send OTP to Email")
                            </button>
                        }
                        else
                        {
                            <div class="acc-form-group">
                                <label>Enter OTP</label>
                                <input @bind="otp" placeholder="6-digit OTP" maxlength="6" />
                            </div>
                            <div class="acc-form-group">
                                <label>New Password</label>
                                <input type="password" @bind="newPassword"
                                       placeholder="New password" />
                            </div>
                            <div class="acc-form-group">
                                <label>Confirm Password</label>
                                <input type="password" @bind="confirmPassword"
                                       placeholder="Confirm password" />
                            </div>
                            <div style="display:flex;gap:12px;">
                                <button class="acc-save-btn" disabled="@isSaving"
                                        @onclick="ChangePassword">
                                    @(isSaving ? "Changing..." : "Change Password")
                                </button>
                                <button class="acc-cancel-btn"
                                        @onclick="() => otpSent = false">
                                    Cancel
                                </button>
                            </div>
                        }
                    </div>
                }

                @* ══════════════ DELETE TAB ══════════════ *@
                @if (activeTab == "delete")
                {
                    <div class="acc-card">
                        <div class="acc-card-title">Delete Account</div>
                        @if (!string.IsNullOrEmpty(deleteError))
                        {
                            <div class="acc-error">&#10007; @deleteError</div>
                        }
                        <p class="acc-pass-info">
                            Once you delete your account all your data
                            will be permanently removed.
                            This action cannot be undone.
                        </p>
                        <div class="acc-delete-box">
                            <div class="acc-delete-icon">&#9888;</div>
                            <div class="acc-delete-text">
                                Are you sure you want to delete your account?
                            </div>
                        </div>
                        <button class="acc-delete-btn" disabled="@isSaving"
                                @onclick="DeleteAccount">
                            @(isSaving ? "Deleting..." : "Delete My Account")
                        </button>
                    </div>
                }

            </div>
        </div>
    }

</div>

@code {

    // ── Profile ──
    ProfileDto? profile;
    UpdateProfileDto editDto = new();
    bool isLoading = true;
    bool isSaving = false;
    string activeTab = "menu";
    string profileSuccess = string.Empty;
    string profileError = string.Empty;

    // ── Password ──
    bool otpSent = false;
    string otp = string.Empty;
    string newPassword = string.Empty;
    string confirmPassword = string.Empty;
    string passSuccess = string.Empty;
    string passError = string.Empty;

    // ── Delete ──
    string deleteError = string.Empty;

    // ── Address ──
    List<CustomerAddressDto> addresses = new();
    bool showAddAddress = false;
    UpdateAddressDto addressForm = new();
    CustomerAddressDto? editingAddress = null;
    string addressSuccess = string.Empty;
    string addressError = string.Empty;

    // ════════════════════════════════════
    //  INIT
    // ════════════════════════════════════
    protected override async Task OnInitializedAsync()
    {
        profile = await AccountSvc.GetProfileAsync();

        if (profile != null)
        {
            editDto.FirstName = profile.FirstName;
            editDto.LastName = profile.LastName;
            editDto.Phone = profile.Phone;
            editDto.Email = profile.Email;
        }

        addresses = await AddressSvc.GetMyAddressesAsync();
        isLoading = false;
    }

    // ════════════════════════════════════
    //  PROFILE
    // ════════════════════════════════════
    async Task SaveProfile()
    {
        profileSuccess = string.Empty;
        profileError = string.Empty;
        isSaving = true;

        var success = await AccountSvc.UpdateProfileAsync(editDto);
        isSaving = false;

        if (success)
        {
            profileSuccess = "Profile updated successfully!";
            _ = HideProfileSuccess();
            profile = await AccountSvc.GetProfileAsync();
        }
        else
        {
            profileError = "Failed to update. Please try again.";
        }
    }

    // ════════════════════════════════════
    //  ADDRESS
    // ════════════════════════════════════
    void OpenAddForm()
    {
        editingAddress = null;
        addressForm = new UpdateAddressDto();
        addressSuccess = string.Empty;
        addressError = string.Empty;
        showAddAddress = true;
    }

    async Task HideAddressSuccess()
    {
        await Task.Delay(3000); // 3 seconds
        addressSuccess = string.Empty;
        StateHasChanged();
    }


    void OpenEditForm(CustomerAddressDto a)
    {
        editingAddress = a;
        addressForm = new UpdateAddressDto
        {
            Id = a.Id,
            FullName = a.FullName,
            PhoneNumber = a.PhoneNumber,
            AddressLine1 = a.AddressLine1,
            AddressLine2 = a.AddressLine2,
            Landmark = a.Landmark,
            City = a.City,
            State = a.State,
            ZipCode = a.ZipCode,
            Country = a.Country,
            AddressType = a.AddressType,
            IsDefault = a.IsDefault
        };
        addressSuccess = string.Empty;
        addressError = string.Empty;
        showAddAddress = true;
    }

    void CloseAddressForm()
    {
        showAddAddress = false;
        editingAddress = null;
        addressForm = new UpdateAddressDto();
    }

    async Task SaveAddress()
    {
        addressSuccess = string.Empty;
        addressError = string.Empty;

        if (string.IsNullOrWhiteSpace(addressForm.FullName) ||
            string.IsNullOrWhiteSpace(addressForm.AddressLine1) ||
            string.IsNullOrWhiteSpace(addressForm.City) ||
            string.IsNullOrWhiteSpace(addressForm.ZipCode))
        {
            addressError = "Please fill in all required fields.";
            return;
        }

        isSaving = true;

        if (editingAddress != null)
        {
            var (success, error) = await AddressSvc.UpdateAddressAsync(addressForm);
            if (success)
            {
                addressSuccess = "Address updated successfully!";
                _ = HideAddressSuccess();
                CloseAddressForm();
                addresses = await AddressSvc.GetMyAddressesAsync();
            }
            else
            {
                addressError = error ?? "Failed to update address.";
            }
        }
        else
        {
            var createDto = new CreateAddressDto
            {
                FullName = addressForm.FullName,
                PhoneNumber = addressForm.PhoneNumber,
                AddressLine1 = addressForm.AddressLine1,
                AddressLine2 = addressForm.AddressLine2,
                Landmark = addressForm.Landmark,
                City = addressForm.City,
                State = addressForm.State,
                ZipCode = addressForm.ZipCode,
                Country = string.IsNullOrWhiteSpace(addressForm.Country) ? "India" : addressForm.Country,
                AddressType = addressForm.AddressType,
                IsDefault = addressForm.IsDefault
            };

            var (success, error) = await AddressSvc.AddAddressAsync(createDto);
            if (success)
            {
                addressSuccess = "Address added successfully!";
                _ = HideAddressSuccess();
                CloseAddressForm();
                addressForm = new UpdateAddressDto();
                editingAddress = null;
                addresses = await AddressSvc.GetMyAddressesAsync();
            }
            else
            {
                addressError = error ?? "Failed to add address.";
            }
        }

        isSaving = false;
    }

    async Task DeleteAddress(string id)
    {
        var (success, error) = await AddressSvc.DeleteAddressAsync(id);
        if (success)
            addresses = await AddressSvc.GetMyAddressesAsync();
        else
            addressError = error ?? "Failed to delete address.";
    }

    // ════════════════════════════════════
    //  PASSWORD
    // ════════════════════════════════════
    async Task SendOtp()
    {
        isSaving = true;
        passError = string.Empty;

        var model = new ForgotPasswordModel
        {
            Email = profile?.Email ?? string.Empty,
            Phone = profile?.Phone ?? string.Empty
        };

        var result = await AuthSvc.ForgotPasswordAsync(model);
        isSaving = false;

        if (result == "ok") otpSent = true;
        else passError = "Failed to send OTP. Please try again.";
    }

    async Task ChangePassword()
    {
        passSuccess = string.Empty;
        passError = string.Empty;

        if (string.IsNullOrEmpty(otp))
        {
            passError = "Please enter the OTP.";
            return;
        }
        if (newPassword != confirmPassword)
        {
            passError = "Passwords do not match.";
            return;
        }
        if (newPassword.Length < 6)
        {
            passError = "Password must be at least 6 characters.";
            return;
        }

        isSaving = true;

        var model = new ResetPasswordModel
        {
            Email = profile?.Email ?? string.Empty,
            Otp = otp,
            NewPassword = newPassword,
            ConfirmPassword = confirmPassword
        };

        var result = await AuthSvc.ResetPasswordAsync(model);
        isSaving = false;

        if (result == "ok")
        {
            passSuccess = "Password changed successfully!";
            otpSent = false;
            otp = string.Empty;
            newPassword = string.Empty;
            confirmPassword = string.Empty;
        }
        else
        {
            passError = "Invalid or expired OTP. Please try again.";
        }
    }

    // ════════════════════════════════════
    //  DELETE ACCOUNT
    // ════════════════════════════════════
    async Task DeleteAccount()
    {
        var confirm = await JS.InvokeAsync<bool>(
            "confirm",
            "Are you sure? This will permanently delete your account.");

        if (!confirm) return;

        isSaving = true;
        deleteError = string.Empty;

        try
        {
            var request = new HttpRequestMessage(
                HttpMethod.Delete,
                $"api/users/customers/delete?email={profile?.Email}");
            request.SetBrowserRequestCredentials(BrowserRequestCredentials.Include);

            var response = await Http.SendAsync(request);

            if (response.IsSuccessStatusCode)
            {
                await JS.InvokeVoidAsync("localStorage.removeItem", "role");
                await JS.InvokeVoidAsync("localStorage.removeItem", "token");

                if (AuthStateProvider is CustomAuthStateProvider p)
                    p.MarkUserAsLoggedOut();

                Navigation.NavigateTo("/", true);
            }
            else
            {
                deleteError = "Failed to delete account. Please try again.";
            }
        }
        catch
        {
            deleteError = "Something went wrong. Please try again.";
        }

        isSaving = false;
    }

    // ════════════════════════════════════
    //  LOGOUT / BACK
    // ════════════════════════════════════
    async Task Logout()
    {
        await Http.PostAsync("api/auth/logout", null);
        await JS.InvokeVoidAsync("localStorage.removeItem", "role");
        await JS.InvokeVoidAsync("localStorage.removeItem", "token");

        if (AuthStateProvider is CustomAuthStateProvider provider)
            provider.MarkUserAsLoggedOut();

        Navigation.NavigateTo("/", true);
    }

    async Task GoBack()
    {
        await JS.InvokeVoidAsync("history.back");
    }

    
    async Task HideProfileSuccess()
    {
        await Task.Delay(3000);
        profileSuccess = string.Empty;
        StateHasChanged();
    }
}