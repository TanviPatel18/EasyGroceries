@inherits LayoutComponentBase
@inject HttpClient Http

@using ECommerceUI.Models.Catalog
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@using ECommerceUI.Layout
@inject NavigationManager Navigation

<div class="layout-container">

    <header class="top-navbar">

        <div class="logo" @onclick='() => Navigation.NavigateTo("/")'>freshora</div>

        <div class="search-bar">
            <div class="search-wrap">
                <span class="search-icon">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none"
                         stroke="currentColor" stroke-width="2"
                         stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="11" cy="11" r="8" />
                        <line x1="21" y1="21" x2="16.65" y2="16.65" />
                    </svg>
                </span>
                <input placeholder="Search products..."
                       value="@searchText"
                       @oninput="OnSearchInput"
                       @onkeydown="HandleSearchKey"
                       autocomplete="off" />
                @if (searchResults.Any())
                {
                    <div class="search-dropdown">
                        @foreach (var p in searchResults)
                        {
                            <div class="search-drop-item" @onclick="() => GoToProduct(p.Id)">
                                <span class="drop-name">@p.ProductName</span>
                                @* <span class="drop-price">₹@p.Price</span> *@
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="nav-icons">

            <NavLink href="/wishlist" class="nav-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="18" height="18">
                    <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" />
                </svg>
                <span>Wishlist</span>
            </NavLink>

            <NavLink href="/cart" class="nav-btn">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="18" height="18">
                    <circle cx="9" cy="21" r="1" />
                    <circle cx="20" cy="21" r="1" />
                    <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6" />
                </svg>
                <span>Cart</span>
            </NavLink>

            <AuthorizeView>
                <Authorized Context="authState">

                    <div class="nav-divider"></div>

                    @if (authState.User.IsInRole("Admin"))
                    {
                        <NavLink href="/admin/products" class="nav-btn admin-btn">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="18" height="18">
                                <rect x="2" y="3" width="20" height="14" rx="2" ry="2" />
                                <path d="M8 21h8M12 17v4" />
                            </svg>
                            <span>Administration</span>
                        </NavLink>
                    }

                    <NavLink href="/my-account" class="nav-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="18" height="18">
                            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                            <circle cx="12" cy="7" r="4" />
                        </svg>
                        <span>Account</span>
                    </NavLink>

                </Authorized>
                <NotAuthorized>
                    <NavLink href="/login" class="nav-btn">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" width="18" height="18">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <polyline points="10 17 15 12 10 7" />
                            <line x1="15" y1="12" x2="3" y2="12" />
                        </svg>
                        <span>Login</span>
                    </NavLink>
                </NotAuthorized>
            </AuthorizeView>

        </div>

    </header>

    <div class="category-bar">
        @foreach (var category in categories)
        {
            <div class="category-item" @onclick="() => OpenCategory(category.Id)">
                @category.Name
            </div>
        }
    </div>

    <div class="page-content">
        @Body
    </div>

    <Footer />

</div>

@code {
    List<CategoryDto> categories = new();
    string searchText = "";
    private List<ProductDto> searchResults = new();

    protected override async Task OnInitializedAsync()
    {
        categories = await Http.GetFromJsonAsync<List<CategoryDto>>
            ("api/catalog/categories/GetAll");
    }

    void SearchProduct()
    {
        searchResults = new();
        Navigation.NavigateTo($"/products/all?search=" + searchText);
    }

    void OpenCategory(string id)
    {
        Navigation.NavigateTo($"/products/{id}");
    }

    async Task Logout()
    {
        await JS.InvokeVoidAsync("localStorage.removeItem", "role");
        if (AuthStateProvider is CustomAuthStateProvider provider)
        {
            provider.MarkUserAsLoggedOut();
        }
        Navigation.NavigateTo("/", true);
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        searchText = e.Value?.ToString() ?? "";
        if (searchText.Length < 3)
        {
            searchResults = new();
            return;
        }
        searchResults = await Http.GetFromJsonAsync<List<ProductDto>>(
            $"api/catalog/products/search-suggestions?q={searchText}") ?? new();
    }

    void GoToProduct(string id)
    {
        searchResults = new();
        searchText = "";
        Navigation.NavigateTo($"/product/{id}");
    }
    void HandleSearchKey(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            Navigation.NavigateTo($"/products/all?search={searchText}");
        }
    }
}